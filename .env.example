# Database Configuration
# Example: postgresql://username:password@localhost/crypto
POSTGRES_URL=postgresql://postgres:password@localhost/crypto

# Ed25519 Signing Key (Private Key in Hex)
# Generate with: python generate_keys.py
# Keep this secret! Do not commit to version control.
VERIFIER_PRIVATE_KEY_HEX=your_private_key_hex_here

# Public Key (for reference / sharing with verifiers)
# Generated from private key
VERIFIER_PUBLIC_KEY_HEX=your_public_key_hex_here

# Key ID (reference name for this key in database)
KEY_ID=key-2026-01
